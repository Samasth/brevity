# ─── SEC EDGAR ────────────────────────────────────────────────────────────────
# No API key required. The SEC's fair-use policy asks for a User-Agent
# identifying who you are. Use your real email so they can contact you if
# something goes wrong with your usage.
EDGAR_CONTACT_EMAIL=your.name@example.com

# ─── Financial Modeling Prep ──────────────────────────────────────────────────
# Free 250 req/day. Used for current quote, profile, real-time ratios.
# Get a key: https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=

# ─── Finnhub (recommended) ────────────────────────────────────────────────────
# Free 60 req/min. Adds Forward P/E + fills FMP-paywalled tickers (recent IPOs
# like CRWV, NBIS, smaller caps). Email-only signup.
# Get a key: https://finnhub.io/register
FINNHUB_API_KEY=

# ─── Alpha Vantage (optional) ─────────────────────────────────────────────────
# Free 25 req/day. Only needed for analyst consensus price target
# (Finnhub gates that on premium). Email-only signup.
# Get a key: https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=

# ─── Twelve Data (not yet wired, reserved for future) ─────────────────────────
# Free 800 req/day, 8 req/min. Has forwardPE pre-computed. Email-only signup.
# Get a key: https://twelvedata.com/account
# The brevity codebase does NOT currently use this key — it's here as a
# placeholder for a future `data_sources/twelvedata.py` adapter.
TWELVEDATA_API_KEY=

# ─── Polygon.io ───────────────────────────────────────────────────────────────
# Email-only signup (no SSN, no KYC, no brokerage account). Required for the
# Gamma Exposure page IF you don't have Tradier/IBKR. Their Options Starter
# plan ($29/mo) gives full chains + greeks + open interest.
# Free tier covers some equity data but excludes options chains.
# Signup: https://polygon.io/dashboard/signup
POLYGON_API_KEY=

# ─── Tradier ──────────────────────────────────────────────────────────────────
# Free options data, BUT signup requires a full brokerage account application:
# SSN, US address, KYC. Their public form gates by US citizen / permanent
# resident status. If you can get through their KYC (or already have a Tradier
# account), this gives you free options chains.
# Signup: https://tradier.com
TRADIER_TOKEN=
# "sandbox" = 15-min delayed (still requires the same KYC); "production" = real-time
TRADIER_ENV=sandbox
